# AutoCurb production env template. Copy to .env.prod and fill in.
# Used by docker-compose.prod.yml.

# --- Required ---
POSTGRES_PASSWORD=change-me-strong-password
JWT_SECRET=generate-with-openssl-rand-hex-32-at-least-32-bytes-please
COOKIE_DOMAIN=.autocurb.example
FSBO_API_URL=https://api.autocurb.example

# --- Integrations (each unlocks features; blank = feature off) ---
ANTHROPIC_API_KEY=

EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=

MARKETCHECK_API_KEY=
PROXY_URL=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM_NUMBER=
TWILIO_STATUS_CALLBACK=https://api.autocurb.example/webhooks/twilio/status
