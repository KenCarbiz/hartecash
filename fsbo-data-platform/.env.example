DATABASE_URL=postgresql+psycopg://fsbo:fsbo@localhost:5432/fsbo
ANTHROPIC_API_KEY=
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
EBAY_MARKETPLACE=EBAY_US
PROXY_URL=
LOG_LEVEL=INFO

# Twilio SMS (A2P 10DLC). Leave blank to disable sending.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM_NUMBER=
TWILIO_STATUS_CALLBACK=

# Marketcheck legal aggregator (licensed data from Autotrader / Cars.com /
# CarGurus / Edmunds / TrueCar). See https://apidocs.marketcheck.com/
MARKETCHECK_API_KEY=

# Auth. In production set ENV_MODE=production and a strong JWT_SECRET.
ENV_MODE=dev
JWT_SECRET=change-me-in-production-dev-only-32-bytes-min
SESSION_DAYS=14
COOKIE_DOMAIN=
COOKIE_SECURE=false

# Public origin used to build URLs in outbound emails.
# Example: https://app.autocurb.com
APP_ORIGIN=

# Transactional email. Backends: console (default — logs to stdout),
# sendgrid (HTTP API), smtp (any SMTP server).
EMAIL_BACKEND=console
EMAIL_FROM=noreply@autocurb.local
EMAIL_FROM_NAME=AutoCurb
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
